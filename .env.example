# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Paths ─────────────────────────────────────────────────────────────────────
GTA_DATA_DIR=data
GTA_OUTPUT_DIR=outputs

# ── Logging ───────────────────────────────────────────────────────────────────
GTA_LOG_LEVEL=INFO

# ── Network behaviour ─────────────────────────────────────────────────────────
GTA_REQUEST_DELAY_S=1.0
GTA_MAX_RETRIES=3
GTA_USER_AGENT=GdyniaThermalAudit/0.1 (academic research; contact: researcher@example.com)

# ── Target platform ───────────────────────────────────────────────────────────
GTA_TARGET_URL=https://termalne.obliview.com
GTA_VIEWER_URL=https://termalne.obliview.com

# ── Config ────────────────────────────────────────────────────────────────────
GTA_CONFIG_PATH=config/config.example.yaml
